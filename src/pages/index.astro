---
import Layout from "../layouts/Layout.astro";
import { getProducts } from "../lib/sheets";

const products = await getProducts();
// Definimos las categorías como un objeto para manejar el texto visible y el ID de filtro
const categoriasDefinidas = [
  { id: "todos", texto: "Todos" },
  { id: "toppers", texto: "Toppers" },
  { id: "escudos", texto: "Escudos" },
  { id: "multicolor", texto: "Multicolor" }
];
---

<Layout title="Catálogo 3D">
  <div class="max-w-7xl mx-auto py-10 px-4">
    <h1 class="text-4xl md:text-6xl font-black text-center mb-10 text-white tracking-tighter uppercase">
      Catálogo Exclusivo
    </h1>

    <div class="flex justify-center mb-12 px-4">
      <nav class="categorias-unificadas-container">
        {categoriasDefinidas.map((cat, index) => (
          <button
            class={`categoria-btn ${index === 0 ? 'active' : ''}`}
            data-categoria={cat.id}
          >
            {cat.texto}
          </button>
        ))}
      </nav>
    </div>

    <div class="flex justify-center mb-16 px-4">
      <div class="search-box-vibrant">
        <span class="search-icon">🔍</span>
        <input
          id="searchInput"
          type="text"
          placeholder="Buscar producto por nombre..."
          class="input-neon"
        />
      </div>
    </div>

    <div id="productGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 xl:grid-cols-3 gap-10">
      {products.map(product => (
        <div
          class="product-item p-8 flex flex-col"
          data-nombre={String(product.nombre || "").toLowerCase()}
          data-categoria={String(product.categoria || "").toLowerCase()}
        >
          <div class="relative z-10 mb-2">
            <h2 class="text-3xl font-extrabold text-white leading-tight tracking-tight">
              {String(product.nombre || "")}
            </h2>
            <p class="subtitulo-card text-lg">
              {product.categoria === 'toppers' ? 'Diseños a Medida' : 'Accesorios 3D de Alta Calidad'}
            </p>
          </div>

          <div class="flex-1 flex items-center justify-center p-6 relative">
            <img
              src={product.imagenes?.[0] || "https://via.placeholder.com/400"}
              alt={product.nombre}
              class="max-h-64 w-auto object-contain drop-shadow-[0_25px_40px_rgba(0,0,0,0.7)]"
            />
          </div>

         <div class="relative z-10 mt-6 flex flex-col gap-4">
  <p class="precio-card">${product.precio}.00</p>
  
  <!-- Botón ocupa el 80% del ancho y está centrado -->
  <div class="flex justify-center">
    <a 
      href={`/producto/${product.id}`} 
      class="ver-detalles-btn no-underline inline-block w-5/5 mx-auto text-center"
    >
      Ver Detalles
    </a>
  </div>
</div>

        </div>
      ))}
    </div>
  </div>

  <script>
    const setupFilters = () => {
      const input = document.getElementById("searchInput");
      const items = document.querySelectorAll(".product-item");
      const botones = document.querySelectorAll(".categoria-btn");

      let catActual = "todos";

      const filtrar = () => {
        const busqueda = (input?.value || "").toLowerCase().trim();
        items.forEach(item => {
          const nombre = item.dataset.nombre || "";
          const categoria = item.dataset.categoria || "";
          const coincideTexto = nombre.includes(busqueda);
          const coincideCat = catActual === "todos" || categoria === catActual;
          
          item.style.display = (coincideTexto && coincideCat) ? "flex" : "none";
        });
      };

      input?.addEventListener("input", filtrar);

      botones.forEach(btn => {
        btn.addEventListener("click", () => {
          catActual = btn.dataset.categoria;
          botones.forEach(b => b.classList.remove("active"));
          btn.classList.add("active");
          filtrar();
        });
      });
    };

    setupFilters();
    document.addEventListener('astro:after-swap', setupFilters);
  </script>
</Layout>