---
import Layout from "../layouts/Layout.astro";
import { getProducts } from "../lib/sheets";

const products = await getProducts();

const categoriasDefinidas = [
  { id: "todos", texto: "Todos" },
  { id: "toppers", texto: "Toppers" },
  { id: "escudos", texto: "Escudos" },
  { id: "multicolor", texto: "Multicolor" }
];
---

<Layout title="Noctura | Catálogo 3D">
  <div class="max-w-7xl mx-auto py-6 md:py-10 px-4">
    <h1 class="text-3xl md:text-6xl font-black text-center mb-8 text-white tracking-tighter uppercase leading-none">
      Catálogo Exclusivo
    </h1>

    <div class="flex justify-center mb-10 px-4">
      <nav class="categorias-wrapper">
        <button id="mobileMenuBtn" class="mobile-menu-trigger">
          <span id="activeCategoryName">Todos</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>

        <div id="categoriesList" class="categorias-unificadas-container">
          {categoriasDefinidas.map((cat, index) => (
            <button
              class={`categoria-btn ${index === 0 ? 'active' : ''}`}
              data-categoria={cat.id}
            >
              {cat.texto}
            </button>
          ))}
        </div>
      </nav>
    </div>

    <div class="flex justify-center mb-12 px-2">
      <div class="search-box-vibrant w-full max-w-md">
        <span class="search-icon">🔍</span>
        <input
          id="searchInput"
          type="text"
          placeholder="¿Qué estás buscando hoy?..."
          class="input-neon"
        />
      </div>
    </div>

    <div id="productGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-10">
      {products.map(product => (
        <div
          class="product-item p-6 md:p-8 flex flex-col"
          data-nombre={String(product.nombre || "").toLowerCase()}
          data-categoria={String(product.categoria || "").toLowerCase()}
        >
          <div class="relative z-10 mb-2">
            <h2 class="text-2xl md:text-3xl font-extrabold text-white leading-tight tracking-tight">
              {String(product.nombre || "")}
            </h2>
            <p class="subtitulo-card text-sm md:text-lg opacity-70">
              {product.categoria === 'toppers' ? 'Diseños a Medida' : 'Accesorios 3D'}
            </p>
          </div>

          <div class="flex-1 flex items-center justify-center p-4 relative">
            <img
              src={product.imagenes?.[0] || "https://via.placeholder.com/400"}
              alt={product.nombre}
              class="max-h-48 md:max-h-64 w-auto object-contain drop-shadow-2xl"
            />
          </div>

          <div class="relative z-10 mt-4 flex flex-col gap-4">
            <p class="precio-card text-2xl md:text-3xl font-bold text-white">${product.precio}.00</p>
            <div class="flex justify-center">
              <a 
                href={`/producto/${product.id}`} 
                class="ver-detalles-btn no-underline inline-block w-full text-center py-3 bg-orange-600 rounded-xl font-bold"
              >
                Ver Detalles
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div id="paginationControls" class="pagination-container-responsive mt-12">
      <button id="prevPage" class="pagination-btn-vibrant-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        <span class="hidden sm:inline">Anterior</span>
      </button>
      
      <div class="page-indicator-mobile">
        <span class="current-label">PÁGINA</span>
        <span id="pageInfo" class="page-number-sm text-white font-black">1 / 1</span>
      </div>

      <button id="nextPage" class="pagination-btn-vibrant-sm">
        <span class="hidden sm:inline">Siguiente</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>
  </div>

  <script>
    const setupCatalog = () => {
      const input = document.getElementById("searchInput");
      const items = Array.from(document.querySelectorAll(".product-item"));
      const botones = document.querySelectorAll(".categoria-btn");
      const prevBtn = document.getElementById("prevPage");
      const nextBtn = document.getElementById("nextPage");
      const pageInfo = document.getElementById("pageInfo");
      
      // Elementos del menú mobile
      const menuBtn = document.getElementById("mobileMenuBtn");
      const catList = document.getElementById("categoriesList");
      const activeName = document.getElementById("activeCategoryName");

      const ITEMS_PER_PAGE = 6;
      let currentPage = 1;
      let filteredItems = [...items];

      // Lógica Desplegable Mobile
      menuBtn?.addEventListener("click", () => {
        catList?.classList.toggle("show");
      });

      const updatePagination = () => {
        const totalPages = Math.ceil(filteredItems.length / ITEMS_PER_PAGE) || 1;
        items.forEach(item => item.style.display = "none");
        const start = (currentPage - 1) * ITEMS_PER_PAGE;
        filteredItems.slice(start, start + ITEMS_PER_PAGE).forEach(item => item.style.display = "flex");

        pageInfo.textContent = `${currentPage} / ${totalPages}`;
        prevBtn.disabled = currentPage === 1;
        nextBtn.disabled = currentPage === totalPages;
        prevBtn.style.opacity = prevBtn.disabled ? "0.3" : "1";
        nextBtn.style.opacity = nextBtn.disabled ? "0.3" : "1";
      };

      const filtrar = (catId = null) => {
        const busqueda = (input?.value || "").toLowerCase().trim();
        const activeBtn = document.querySelector(".categoria-btn.active");
        const catActual = catId || activeBtn?.dataset.categoria || "todos";

        filteredItems = items.filter(item => {
          const nombre = item.dataset.nombre || "";
          const categoria = item.dataset.categoria || "";
          return nombre.includes(busqueda) && (catActual === "todos" || categoria === catActual);
        });

        currentPage = 1;
        updatePagination();
      };

      input?.addEventListener("input", () => filtrar());

      botones.forEach(btn => {
        btn.addEventListener("click", () => {
          botones.forEach(b => b.classList.remove("active"));
          btn.classList.add("active");
          
          if (window.innerWidth <= 640) {
            activeName.textContent = btn.textContent;
            catList?.classList.remove("show");
          }
          
          filtrar(btn.dataset.categoria);
        });
      });

      nextBtn.onclick = () => { currentPage++; updatePagination(); window.scrollTo({ top: 300, behavior: 'smooth' }); };
      prevBtn.onclick = () => { currentPage--; updatePagination(); window.scrollTo({ top: 300, behavior: 'smooth' }); };

      filtrar();
    };

    setupCatalog();
    document.addEventListener('astro:after-swap', setupCatalog);
  </script>

  <style>
    .categorias-wrapper { position: relative; }

    /* BOTONES CATEGORÍA (ESCRITORIO) */
    .categorias-unificadas-container {
      display: flex;
      gap: 10px;
      background: rgba(255, 255, 255, 0.05);
      padding: 8px;
      border-radius: 20px;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .categoria-btn {
      padding: 10px 20px;
      border-radius: 15px;
      border: none;
      color: rgba(255, 255, 255, 0.6);
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
      background: transparent;
    }

    .categoria-btn.active {
      background: #f97316;
      color: white;
      box-shadow: 0 4px 15px rgba(249, 115, 22, 0.4);
    }

    /* ESTILO DROPDOWN MOBILE */
    .mobile-menu-trigger { display: none; }

    @media (max-width: 640px) {
      .mobile-menu-trigger {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 220px;
        padding: 14px 20px;
        background: rgba(255, 255, 255, 0.1);
        border: 2px solid #f97316;
        border-radius: 16px;
        color: white;
        font-weight: 800;
        text-transform: uppercase;
        backdrop-filter: blur(10px);
      }

      .categorias-unificadas-container {
        display: none;
        flex-direction: column;
        position: absolute;
        top: 65px;
        left: 50%;
        transform: translateX(-50%);
        width: 220px;
        background: #1a1a1a;
        z-index: 100;
        padding: 5px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 15px 30px rgba(0,0,0,0.8);
      }

      .categorias-unificadas-container.show {
        display: flex;
        animation: fadeInDown 0.2s ease-out;
      }

      .categoria-btn {
        width: 100%;
        text-align: left;
        padding: 15px;
        border-radius: 10px;
      }
    }

    @keyframes fadeInDown {
      from { opacity: 0; transform: translate(-50%, -10px); }
      to { opacity: 1; transform: translate(-50%, 0); }
    }

    /* ESTILOS PAGINACIÓN */
    .pagination-container-responsive {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(0,0,0,0.3);
      padding: 15px;
      border-radius: 20px;
      border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .pagination-btn-vibrant-sm {
      background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
      color: white;
      border: none;
      padding: 10px 20px;
      border-radius: 12px;
      font-weight: 800;
      display: flex;
      align-items: center;
      gap: 8px;
    }
  </style>
</Layout>