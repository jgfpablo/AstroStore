---
import Layout from "../layouts/Layout.astro";
import { getProducts } from "../lib/sheets";

// 🔥 Traemos TODOS los productos (sin filtrar en servidor)
const products = await getProducts();
---

<Layout title="Catálogo">

  <h1 class="text-3xl md:text-5xl font-extrabold text-center mb-8">
    Nuestros Productos
  </h1>

  <!-- 🔍 BUSCADOR -->
  <div class="flex justify-center mb-10">
    <input
      id="searchInput"
      type="text"
      placeholder="Buscar producto... (ej: poke)"
      class="w-full max-w-xl px-4 py-3 rounded-xl 
             bg-white/10 border border-white/20 
             text-white placeholder-white/50
             focus:outline-none focus:ring-2 focus:ring-pink-500"
    />
  </div>

  <!-- GRID -->
  <div id="productGrid" class="grid grid-cols-1 md:grid-cols-2 gap-6">

    {products.map(product => (
      <div 
        class="product-item group bg-gradient-to-br from-indigo-800/80 to-purple-800/80 
               p-5 rounded-2xl shadow-xl transition"
        data-nombre={String(product.nombre || "").toLowerCase().trim()}
      >

        <a href={`/producto/${product.id}`}>

          <div class="flex flex-col md:flex-row items-center gap-6">

            <div class="w-full md:w-60 h-52 md:h-60 overflow-hidden rounded-xl">
              <img 
                src={product.imagenes[0] || "https://via.placeholder.com/300"} 
                class="w-full h-full object-cover"
              />
            </div>

            <div class="flex-1 text-center md:text-left">

              <h2 class="text-xl md:text-2xl font-bold">
                {product.nombre}
              </h2>

              <p class="text-white/70 text-sm mt-1 mb-2">
                {product.descripcion.slice(0, 60)}...
              </p>

              <p class="text-2xl md:text-3xl font-bold mt-2">
                ${product.precio}
              </p>

            </div>
          </div>

        </a>

      </div>
    ))}

  </div>

  <!-- SCRIPT BUSCADOR -->
  <script>
    const input = document.getElementById("searchInput");
    const items = document.querySelectorAll(".product-item");

    input.addEventListener("input", () => {
      const value = input.value.toLowerCase().trim();

      items.forEach(item => {
        const nombre = (item.dataset.nombre || "").toLowerCase();

        if (nombre.includes(value)) {
          item.style.display = "block";
        } else {
          item.style.display = "none";
        }
      });
    });
  </script>

</Layout>