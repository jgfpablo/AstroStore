---
import Layout from "../layouts/Layout.astro";
import { getProducts } from "../lib/sheets";

const products = await getProducts();
const categorias = ["Todos", "Toppers", "Escudos", "Llaveros", "Multicolor"];
---

<Layout title="Catálogo 3D">

  <div class="max-w-7xl mx-auto py-10 px-4">
    <h1 class="text-4xl md:text-6xl font-black text-center mb-10 text-white tracking-tighter uppercase">
      Catálogo Exclusivo
    </h1>

    <div class="flex justify-center mb-8 gap-4 flex-wrap">
      {categorias.map(cat => (
        <button
          class="categoria-btn hover:scale-105"
          data-categoria={cat.toLowerCase()}
        >
          {cat}
        </button>
      ))}
    </div>

    <form id="searchForm" class="flex justify-center mb-16 px-4">
      <input
        id="searchInput"
        type="text"
        placeholder="¿Qué estás buscando hoy?..."
        class="w-full max-w-2xl px-6 py-4 rounded-2xl outline-none text-lg shadow-2xl"
      />
    </form>

    <div id="productGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-10">
      {products.map(product => (
        <div
          class="product-item p-7"
          data-nombre={String(product.nombre || "").toLowerCase()}
          data-categoria={String(product.categoria || "").toLowerCase()}
        >
          <a href={`/producto/${product.id}`} class="absolute inset-0 z-0"></a>

          <div class="relative z-10 mb-2">
            <h2 class="text-2xl font-extrabold text-white leading-none tracking-tight">
              {product.nombre}
            </h2>
            <p class="subtitulo-card">{product.categoria === 'toppers' ? 'Diseños a Medida' : 'Accesorios 3D'}</p>
          </div>

          <div class="flex-1 flex items-center justify-center p-4 relative z-0">
            <img
              src={product.imagenes?.[0] || "https://via.placeholder.com/400"}
              alt={product.nombre}
              class="max-h-52 w-auto object-contain drop-shadow-[0_20px_35px_rgba(0,0,0,0.6)]"
            />
          </div>

          <div class="relative z-10 mt-4">
            <p class="precio-card mb-4">${product.precio}.00</p>
            
            <div class="flex">
                <span class={`ver-detalles-btn ${
                    product.categoria === 'llaveros' ? 'btn-morado' : 
                    product.categoria === 'escudos' ? 'btn-rojo' : ''
                }`}>
                  {product.categoria === 'llaveros' ? 'Ver Más' : 
                   product.categoria === 'toppers' ? 'Ver Detalles' : 'Comprar Ahora'}
                </span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <script>
    const setupFilters = () => {
      const input = document.getElementById("searchInput");
      const items = document.querySelectorAll(".product-item");
      const botones = document.querySelectorAll(".categoria-btn");

      let catActual = "todos";

      const filtrar = () => {
        const busqueda = (input.value || "").toLowerCase().trim();
        items.forEach(item => {
          const nombre = item.dataset.nombre || "";
          const categoria = item.dataset.categoria || "";
          const coincideTexto = nombre.includes(busqueda);
          const coincideCat = catActual === "todos" || categoria === catActual;
          
          item.style.display = (coincideTexto && coincideCat) ? "flex" : "none";
        });
      };

      input.addEventListener("input", filtrar);

      botones.forEach(btn => {
        btn.addEventListener("click", () => {
          catActual = btn.dataset.categoria;
          botones.forEach(b => b.classList.remove("active"));
          btn.classList.add("active");
          filtrar();
        });
      });

      // Botón inicial
      botones[0].classList.add("active");
    };

    setupFilters();
    document.addEventListener('astro:after-swap', setupFilters);
  </script>
</Layout>