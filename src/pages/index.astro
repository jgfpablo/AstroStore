---
import Layout from "../layouts/Layout.astro";
import { getProducts } from "../lib/sheets";

// 🔥 PRODUCTOS
const products = await getProducts();

// 🔥 CATEGORÍAS FIJAS
const categorias = ["todas", "llaveros", "imanes", "toppers"];
---

<Layout title="Catálogo">

  <h1 class="text-3xl md:text-5xl font-extrabold text-center mb-8">
    Nuestros Productos
  </h1>

  <!-- 🏷️ CATEGORÍAS -->
  <div class="flex justify-center mb-6 gap-2 flex-wrap">
    {categorias.map(cat => (
      <button
        class="categoria-btn px-4 py-2 rounded-full border border-white/20 
               bg-white/10 hover:bg-white/20 transition"
        data-categoria={cat}
      >
        {cat}
      </button>
    ))}
  </div>

  <!-- 🔍 BUSCADOR -->
  <form id="searchForm" class="flex justify-center mb-10">
    <input
      id="searchInput"
      type="text"
      placeholder="Buscar producto... (ej: poke)"
      class="w-full max-w-xl px-4 py-3 rounded-xl 
             bg-white/10 border border-white/20 
             text-white placeholder-white/50
             focus:outline-none focus:ring-2 focus:ring-pink-500"
    />
  </form>

  <!-- GRID -->
  <div id="productGrid" class="grid grid-cols-1 md:grid-cols-2 gap-6">

    {products.map(product => (
      <div 
        class="product-item group bg-gradient-to-br from-indigo-800/80 to-purple-800/80 
               p-5 rounded-2xl shadow-xl transition"
        data-nombre={String(product.nombre || "").toLowerCase().trim()}
        data-categoria={product.categoria}
      >

        <a href={`/producto/${product.id}`}>

          <div class="flex flex-col md:flex-row items-center gap-6">

            <div class="w-full md:w-60 h-52 md:h-60 overflow-hidden rounded-xl">
              <img 
                src={product.imagenes[0] || "https://via.placeholder.com/300"} 
                class="w-full h-full object-cover"
              />
            </div>

            <div class="flex-1 text-center md:text-left">

              <h2 class="text-xl md:text-2xl font-bold">
                {product.nombre}
              </h2>

              <p class="text-white/70 text-sm mt-1 mb-2">
                {product.descripcion.slice(0, 60)}...
              </p>

              <p class="text-2xl md:text-3xl font-bold mt-2">
                ${product.precio}
              </p>

            </div>
          </div>

        </a>

      </div>
    ))}

  </div>

  <!-- SCRIPT FILTROS -->
  <script>
    const form = document.getElementById("searchForm");
    const input = document.getElementById("searchInput");
    const items = document.querySelectorAll(".product-item");
    const botones = document.querySelectorAll(".categoria-btn");

    let categoriaActual = "todas";

    function filtrar() {
      const texto = input.value.toLowerCase().trim();

      items.forEach(item => {
        const nombre = (item.dataset.nombre || "").toLowerCase();
        const categoria = item.dataset.categoria;

        const coincideTexto = nombre.includes(texto);
        const coincideCategoria =
          categoriaActual === "todas" || categoria === categoriaActual;

        if (coincideTexto && coincideCategoria) {
          item.style.display = "block";
        } else {
          item.style.display = "none";
        }
      });
    }

    // 🔍 ENTER
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      filtrar();
    });

    // 🏷️ CLICK CATEGORÍAS
    botones.forEach(btn => {
      btn.addEventListener("click", () => {
        categoriaActual = btn.dataset.categoria;

        // estilo activo
        botones.forEach(b => b.classList.remove("bg-white", "text-black"));
        btn.classList.add("bg-white", "text-black");

        filtrar();
      });
    });
  </script>

</Layout>