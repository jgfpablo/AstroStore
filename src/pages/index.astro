---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import { getProducts } from "../lib/sheets";

// 🔥 PRODUCTOS
const products = await getProducts();

// 🔥 CATEGORÍAS FIJAS
const categorias = ["todas", "llaveros", "imanes", "toppers"];
---

<Layout title="Catálogo">

  <h1 class="text-3xl md:text-5xl font-extrabold text-center mb-8 text-white">
    Nuestros Productos
  </h1>

  <!-- 🏷️ CATEGORÍAS -->
  <div class="flex justify-center mb-6 gap-3 flex-wrap">
    {categorias.map(cat => (
      <button
        class="categoria-btn px-5 py-2 rounded-full 
               bg-white/10 backdrop-blur border border-white/20 
               hover:bg-white/20 hover:scale-105 
               transition text-sm font-medium text-white"
        data-categoria={cat}
      >
        {cat}
      </button>
    ))}
  </div>

  <!-- 🔍 BUSCADOR -->
  <form id="searchForm" class="flex justify-center mb-10" on:submit>
    <input
      id="searchInput"
      type="text"
      placeholder="Buscar producto... (ej: poke)"
      class="w-full max-w-xl px-5 py-3 rounded-full 
             bg-white/10 border border-white/20 
             text-white placeholder-white/50
             backdrop-blur
             focus:outline-none focus:ring-2 focus:ring-pink-500
             shadow-lg"
    />
  </form>

  <!-- GRID -->
  <div id="productGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 px-4 md:px-0">

    {products.map(product => (
      <div
        class="product-item relative overflow-hidden rounded-2xl shadow-2xl transition duration-300"
        style="height: 28rem;"
        data-nombre={String(product.nombre || "").toLowerCase().trim()}
        data-categoria={product.categoria}
      >

        <!-- Envolvemos todo en un enlace para que la card sea clicable -->
        <a href={`/producto/${product.id}`} class="block relative w-full h-full">

          <!-- IMAGEN ocupa 80% del alto del card y está centrada -->
          <div class="w-full h-[80%] flex items-center justify-center overflow-hidden bg-gray-800">
            <img
              src={product.imagenes && product.imagenes.length ? product.imagenes[0] : "https://via.placeholder.com/800x800"}
              alt={product.nombre || "Producto"}
              class="w-full h-full object-cover object-center"
            />
          </div>

          <!-- INFO superpuesta sobre la imagen y el resto del card -->
          <div class="absolute inset-0 pointer-events-none">
            <!-- gradiente para mejorar legibilidad: transparente arriba, oscuro abajo -->
            <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/70"></div>

            <!-- contenido colocado con flex para ubicar título arriba y precio+botón abajo -->
            <div class="relative z-10 h-full flex flex-col justify-between p-5">

              <!-- Título arriba a la izquierda -->
              <div class="flex items-start">
                <h2 class="text-lg md:text-xl font-bold text-white drop-shadow mb-0">
                  {product.nombre}
                </h2>
              </div>

              <!-- Espacio central (puedes usarlo para etiquetas, stock, etc.) -->
              <div class="flex-1"></div>

              <!-- Precio sobre el botón, ambos alineados abajo a la izquierda -->
              <div class="flex flex-col items-start gap-2 pointer-events-auto">
                <p class="text-xl md:text-2xl font-extrabold text-green-400">
                  ${product.precio}
                </p>

                <!-- Usamos un span estilizado en lugar de un botón real para evitar elementos interactivos anidados -->
                <span
                  class="px-4 py-2 rounded-lg 
                         bg-gradient-to-r from-orange-500 to-pink-500 
                         hover:from-orange-600 hover:to-pink-600
                         text-white font-semibold shadow-lg transition inline-block"
                >
                  Ver más
                </span>
              </div>

            </div>
          </div>

        </a>

      </div>
    ))}

  </div>

  <!-- SCRIPT FILTROS -->
  <script>
    // Esperamos a que el DOM esté listo por si Tailwind o Astro inyectan algo después
    (function () {
      const form = document.getElementById("searchForm");
      const input = document.getElementById("searchInput");
      const items = document.querySelectorAll(".product-item");
      const botones = document.querySelectorAll(".categoria-btn");

      let categoriaActual = "todas";

      function filtrar() {
        const texto = (input.value || "").toLowerCase().trim();

        items.forEach(item => {
          const nombre = (item.dataset.nombre || "").toLowerCase();
          const categoria = (item.dataset.categoria || "").toLowerCase();

          const coincideTexto = nombre.includes(texto);
          const coincideCategoria =
            categoriaActual === "todas" || categoria === categoriaActual;

          if (coincideTexto && coincideCategoria) {
            item.style.display = "block";
          } else {
            item.style.display = "none";
          }
        });
      }

      // 🔍 ENTER (submit del form)
      form.addEventListener("submit", (e) => {
        e.preventDefault();
        filtrar();
      });

      // Filtrar en tiempo real al escribir (opcional, útil UX)
      input.addEventListener("input", () => {
        filtrar();
      });

      // 🏷️ CLICK CATEGORÍAS
      botones.forEach(btn => {
        btn.addEventListener("click", () => {
          categoriaActual = (btn.dataset.categoria || "todas").toLowerCase();

          botones.forEach(b => b.classList.remove("bg-white", "text-black"));
          btn.classList.add("bg-white", "text-black");

          filtrar();
        });
      });

      // Inicial: marcar "todas"
      botones.forEach(b => {
        if ((b.dataset.categoria || "").toLowerCase() === "todas") {
          b.classList.add("bg-white", "text-black");
        }
      });

      // Ejecutar filtro inicial para respetar búsqueda vacía / categoría por defecto
      filtrar();
    })();
  </script>

</Layout>