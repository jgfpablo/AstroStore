---
import Layout from "../layouts/Layout.astro";
import { getProducts } from "../lib/sheets";

export const prerender = false;

const products = await getProducts();

// --- LÓGICA DE CATEGORÍAS DINÁMICAS ---
// 1. Extraemos todas las categorías, limpiamos espacios y pasamos a minúsculas
const rawCategories = products.map(p => p.categoria?.toLowerCase().trim()).filter(Boolean);

// 2. Usamos Set para eliminar duplicados
const categoriasUnicas = [...new Set(rawCategories)].sort();

// 3. Creamos el array final con "Todos" al principio
const categoriasDefinidas = [
  { id: "todos", texto: "Todos" },
  ...categoriasUnicas.map(cat => ({
    id: cat,
    texto: cat.charAt(0).toUpperCase() + cat.slice(1) // Capitaliza: "escudos" -> "Escudos"
  }))
];
---

<Layout title="Noctura | Catálogo 3D">
  <div class="max-w-7xl mx-auto py-6 md:py-10 px-4">
    <div class="flex flex-col items-center mb-8">
      
       <h1 class="text-3xl md:text-6xl font-black text-center text-white tracking-tighter uppercase leading-none">
         Catálogo Exclusivo
       </h1>
    </div>

    <div class="flex justify-center mb-10 px-4">
      <nav class="categorias-wrapper">
        <button id="mobileMenuBtn" class="mobile-menu-trigger">
          <span id="activeCategoryName">Todos</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>

        <div id="categoriesList" class="categorias-unificadas-container">
          {categoriasDefinidas.map((cat, index) => (
            <button
              class={`categoria-btn ${index === 0 ? 'active' : ''}`}
              data-categoria={cat.id}
            >
              {cat.texto}
            </button>
          ))}
        </div>
      </nav>
    </div>

    <div class="flex justify-center mb-12 px-2">
      <div class="search-box-vibrant w-full max-w-md">
        <span class="search-icon">🔍</span>
        <input
          id="searchInput"
          type="text"
          placeholder="¿Qué estás buscando hoy?..."
          class="input-neon"
        />
      </div>
    </div>

    <div id="productGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-10">
      {products.map(product => (
        <div
          class="product-item p-6 md:p-8 flex flex-col"
          data-nombre={String(product.nombre || "").toLowerCase()}
          data-categoria={String(product.categoria || "").toLowerCase().trim()}
        >
          <div class="relative z-10 mb-2">
            <h2 class="text-2xl md:text-3xl font-extrabold text-white leading-tight tracking-tight">
              {String(product.nombre || "")}
            </h2>
            <p class="subtitulo-card text-sm md:text-lg opacity-70 italic text-orange-400">
              {product.categoria || 'General'}
            </p>
          </div>

          <div class="flex-1 flex items-center justify-center p-4 relative">
            <img
              src={product.imagenes?.[0] || "https://via.placeholder.com/400"}
              alt={product.nombre}
              class="max-h-48 md:max-h-64 w-auto object-contain drop-shadow-2xl"
            />
          </div>

          <div class="relative z-10 mt-4 flex flex-col gap-4">
            <p class="precio-card text-2xl md:text-3xl font-bold text-white">${product.precio}</p>
            <div class="flex justify-center">
              <a 
                href={`/producto/${product.id}`} 
                class="ver-detalles-btn no-underline inline-block w-full text-center py-3 bg-orange-600 rounded-xl font-bold text-white transition-transform hover:scale-105"
              >
                Ver Detalles
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div id="paginationControls" class="pagination-container-vibrant mt-12">
  <button id="prevPage" class="pagination-btn">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
  </button>
  
  <div class="page-info-wrapper">
    <span class="page-label">PÁGINA</span>
    <div class="page-counter">
      <span id="pageInfo" class="text-white">1 / 103</span>
    </div>
  </div>

  <button id="nextPage" class="pagination-btn active">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
  </button>
</div>
  </div>

  <script>
    const setupCatalog = () => {
      const input = document.getElementById("searchInput") as HTMLInputElement;
      const items = Array.from(document.querySelectorAll(".product-item")) as HTMLElement[];
      const botones = document.querySelectorAll(".categoria-btn");
      const prevBtn = document.getElementById("prevPage") as HTMLButtonElement;
      const nextBtn = document.getElementById("nextPage") as HTMLButtonElement;
      const pageInfo = document.getElementById("pageInfo");
      
      const menuBtn = document.getElementById("mobileMenuBtn");
      const catList = document.getElementById("categoriesList");
      const activeName = document.getElementById("activeCategoryName");

      const ITEMS_PER_PAGE = 6;
      let currentPage = 1;
      let filteredItems = [...items];

      menuBtn?.addEventListener("click", () => catList?.classList.toggle("show"));

      const updatePagination = () => {
        const totalPages = Math.ceil(filteredItems.length / ITEMS_PER_PAGE) || 1;
        items.forEach(item => item.style.display = "none");
        const start = (currentPage - 1) * ITEMS_PER_PAGE;
        filteredItems.slice(start, start + ITEMS_PER_PAGE).forEach(item => item.style.display = "flex");

        if(pageInfo) pageInfo.textContent = `${currentPage} / ${totalPages}`;
        if(prevBtn) prevBtn.disabled = currentPage === 1;
        if(nextBtn) nextBtn.disabled = currentPage === totalPages;
      };

      const filtrar = (catId: string | null = null) => {
        const busqueda = (input?.value || "").toLowerCase().trim();
        const activeBtn = document.querySelector(".categoria-btn.active") as HTMLElement;
        const catActual = catId || activeBtn?.dataset.categoria || "todos";

        filteredItems = items.filter(item => {
          const nombre = item.dataset.nombre || "";
          const categoria = item.dataset.categoria || "";
          return nombre.includes(busqueda) && (catActual === "todos" || categoria === catActual);
        });

        currentPage = 1;
        updatePagination();
      };

      input?.addEventListener("input", () => filtrar());

      botones.forEach(btn => {
        btn.addEventListener("click", () => {
          botones.forEach(b => b.classList.remove("active"));
          btn.classList.add("active");
          
          if (window.innerWidth <= 640 && activeName && catList) {
            activeName.textContent = btn.textContent;
            catList.classList.remove("show");
          }
          
          filtrar((btn as HTMLElement).dataset.categoria);
        });
      });

      if(nextBtn) nextBtn.onclick = () => { currentPage++; updatePagination(); window.scrollTo({ top: 300, behavior: 'smooth' }); };
      if(prevBtn) prevBtn.onclick = () => { currentPage--; updatePagination(); window.scrollTo({ top: 300, behavior: 'smooth' }); };

      filtrar();
    };

    setupCatalog();
    document.addEventListener('astro:after-swap', setupCatalog);
  </script>

  <style>
    /* Estilos base (Mantené los que ya tenías o usá estos actualizados) */
    .categorias-wrapper { position: relative; }
    .categorias-unificadas-container {
      display: flex;
      gap: 10px;
      background: rgba(255, 255, 255, 0.05);
      padding: 8px;
      border-radius: 20px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      flex-wrap: wrap;
      justify-content: center;
    }

    .categoria-btn {
      padding: 10px 20px;
      border-radius: 15px;
      border: none;
      color: rgba(255, 255, 255, 0.6);
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
      background: transparent;
      text-transform: capitalize;
    }

    .categoria-btn.active {
      background: #f97316;
      color: white;
      box-shadow: 0 4px 15px rgba(249, 115, 22, 0.4);
    }

    .mobile-menu-trigger { display: none; }

    @media (max-width: 640px) {
      .mobile-menu-trigger {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 220px;
        padding: 14px 20px;
        background: rgba(255, 255, 255, 0.1);
        border: 2px solid #f97316;
        border-radius: 16px;
        color: white;
        font-weight: 800;
        text-transform: uppercase;
      }

      .categorias-unificadas-container {
        display: none;
        flex-direction: column;
        position: absolute;
        top: 65px;
        left: 50%;
        transform: translateX(-50%);
        width: 220px;
        background: #1a1a1a;
        z-index: 100;
        border: 1px solid rgba(255, 255, 255, 0.2);
      }

      .categorias-unificadas-container.show { display: flex; }
      .categoria-btn { width: 100%; text-align: left; }
    }





	/* -----------paginador
----------- */ 
	.pagination-container-vibrant {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    background: rgba(0, 0, 0, 0.534); /* Efecto cristal */
    backdrop-filter: blur(15px);
    padding: 20px 30px;
    border-radius: 40px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    max-width: fit-content;
    margin: 40px auto;
  }

  .page-info-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .page-label {
    font-size: 0.7rem;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .page-counter {
    font-size: 2.2rem;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -1px;
  }

  .pagination-btn {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.3);
    border: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .pagination-btn.active, .pagination-btn:not(:disabled):hover {
    background: #f97316; /* Tu naranja vibrante */
    color: white;
    box-shadow: 0 0 20px rgba(249, 115, 22, 0.4);
  }

  .pagination-btn:disabled {
    cursor: not-allowed;
    opacity: 0.2;
  }

  /* Ajuste para que en mobile no quede gigante */
  @media (max-width: 640px) {
    .pagination-container-vibrant {
      padding: 15px 20px;
      gap: 15px;
    }
    .page-counter {
      font-size: 1.6rem;
    }
    .pagination-btn {
      width: 50px;
      height: 50px;
    }
  }
  </style>
</Layout>