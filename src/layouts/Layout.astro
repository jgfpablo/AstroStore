---
import "../styles/global.css";
const { title = "Catálogo" } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>

  <body class="min-h-screen bg-gradient-to-br from-indigo-700 via-purple-600 to-pink-500 text-white">

    <header class="bg-white/10 backdrop-blur border-b border-white/20 sticky top-0 z-20">
      <div class="max-w-6xl mx-auto p-4 flex justify-between items-center">
        <a href="/" class="text-xl md:text-2xl font-bold">
          🛍️ Catálogo
        </a>
      </div>
    </header>

    <main class="max-w-6xl mx-auto p-4 md:p-6">
      <slot />
    </main>

  </body>
</html>